# =============================================================================
# MerchOps Web App - Local Development Configuration
# =============================================================================
# Non-standard ports to avoid conflicts:
#   - Next.js: 3847, PostgreSQL: 5847, Redis: 6847
# =============================================================================

# Database (PostgreSQL on port 5847)
DATABASE_URL="postgresql://merchops:merchops_dev_password@localhost:5847/merchops_dev"

# NextAuth (App runs on port 3847)
NEXTAUTH_URL="http://localhost:3847"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"

# Shopify OAuth
SHOPIFY_CLIENT_ID="your-shopify-client-id"
SHOPIFY_CLIENT_SECRET="your-shopify-client-secret"
SHOPIFY_SCOPES="read_products,write_products,read_orders,read_customers,write_price_rules,read_inventory,write_inventory"

# Redis (for BullMQ on port 6847)
REDIS_URL="redis://localhost:6847"

# Email Provider (Optional - for win-back emails)
EMAIL_PROVIDER="resend"
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM_ADDRESS="noreply@merchops.com"
EMAIL_SANDBOX_MODE="true"

# AI Provider (Anthropic)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Observability
SENTRY_DSN="your-sentry-dsn"
NODE_ENV="development"
