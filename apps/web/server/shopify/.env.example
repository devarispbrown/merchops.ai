# Shopify OAuth and API Configuration
# Copy this file to .env and fill in your values

# Shopify App Credentials
# Get these from your Shopify Partner Dashboard > Apps > [Your App]
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Your app URL (must match OAuth redirect URI in Shopify app settings)
# Development: http://localhost:3000
# Production: https://your-domain.com
SHOPIFY_APP_URL=http://localhost:3000

# Required OAuth Scopes (comma-separated)
# Minimal scopes for MerchOps MVP functionality
SHOPIFY_SCOPES=read_products,write_products,read_inventory,read_orders,read_customers,write_price_rules,write_discounts

# Token Encryption Key
# CRITICAL: Must be exactly 64 hexadecimal characters (32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHOPIFY_TOKEN_ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Database
# PostgreSQL connection string for storing Shopify connections and cache
DATABASE_URL=postgresql://user:password@localhost:5432/merchops

# Redis (for background jobs)
# Used by BullMQ for webhook processing and sync jobs
REDIS_URL=redis://localhost:6379
