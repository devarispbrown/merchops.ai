# ============================================================================
# MerchOps - Docker Ignore File
# Excludes unnecessary files from Docker build context for faster builds
# ============================================================================

# Dependencies
node_modules
.pnpm-store

# Next.js
.next
out
apps/web/.next
apps/web/out

# Testing
coverage
test-results
playwright-report
.nyc_output
*.log

# Development files
.env
.env.local
.env.*.local
*.env
apps/web/.env
apps/web/.env.local

# Editor directories and files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.sublime-workspace
*.sublime-project

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS Files
.DS_Store
Thumbs.db

# Git
.git
.gitignore
.gitattributes

# Documentation (not needed in runtime)
*.md
!README.md
docs/
CLAUDE*.md
*_DELIVERY.md
*_SUMMARY.md
*_CHECKLIST.md
*_REPORT.md

# CI/CD
.github
.circleci
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Build artifacts
dist
build
*.tsbuildinfo

# Prisma migrations (handled separately in production)
prisma/migrations/*.sql

# Scripts (not needed in runtime)
scripts

# Test files
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__
**/__mocks__
tests/
e2e/
playwright.config.ts
vitest.config.ts

# Temporary files
tmp
temp
*.tmp
.cache

# Package manager files (already in lockfile)
package-lock.json
yarn.lock
