# ============================================================================
# MerchOps - Docker Production Environment Template
# Copy this file to .env.production for production deployments
# ============================================================================

# Application Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Database Configuration (PostgreSQL)
POSTGRES_USER=merchops
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
POSTGRES_DB=merchops_production
POSTGRES_PORT=5432

# Database URL for Prisma (automatically constructed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public&connection_limit=10&pool_timeout=20

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
NEXTAUTH_URL=https://your-domain.com

# Shopify OAuth Configuration
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_SCOPES=read_products,write_products,read_orders,read_customers,read_inventory,write_inventory,write_discounts,read_price_rules,write_price_rules
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# Email Provider (Resend or SendGrid)
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key

# AI Provider Configuration
AI_PROVIDER=anthropic
AI_MODEL_TIER=balanced
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.7

# API Keys for AI providers
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Encryption Configuration
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_64_CHARS

# Observability
SENTRY_DSN=your-sentry-dsn-if-using-sentry
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Feature Flags (optional)
FEATURE_EMAIL_SENDING=false
FEATURE_AUTO_EXECUTION=false
FEATURE_LEARNING_LOOP=true

# Rate Limiting (optional)
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
