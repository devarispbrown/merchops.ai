# =============================================================================
# MerchOps Local Development Configuration
# =============================================================================
# This file contains example environment variables for local development.
# Copy this file to .env and update the values as needed.
#
# IMPORTANT: Non-standard ports are used to avoid conflicts with other projects:
#   - Next.js: 3847 (instead of 3000)
#   - PostgreSQL: 5847 (instead of 5432)
#   - Redis: 6847 (instead of 6379)
# =============================================================================

# Database Configuration
# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Note: Port 5847 is used to avoid conflicts with other local PostgreSQL instances
DATABASE_URL="postgresql://merchops:merchops_dev_password@localhost:5847/merchops_dev?schema=public"

# Redis Configuration
# Redis connection string for BullMQ job queue and caching
# Format: redis://[username]:[password]@HOST:PORT/DATABASE
# Note: Port 6847 is used to avoid conflicts with other local Redis instances
REDIS_URL="redis://localhost:6847/0"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"

# Application URL (update for production)
# Note: Port 3847 is used to avoid conflicts with other local dev servers
NEXTAUTH_URL="http://localhost:3847"

# Shopify OAuth Configuration
# Create a custom app in your Shopify Partner Dashboard
# https://partners.shopify.com/
SHOPIFY_CLIENT_ID="your-shopify-client-id"
SHOPIFY_CLIENT_SECRET="your-shopify-client-secret"

# Shopify OAuth Scopes
# Minimal required scopes for MVP functionality
SHOPIFY_SCOPES="read_products,write_products,read_orders,read_customers,read_inventory,write_inventory,write_discounts,read_price_rules,write_price_rules"

# Sentry Configuration (Error Tracking)
# Create project at https://sentry.io
# Leave empty to disable Sentry
SENTRY_DSN=""

# Email Provider Configuration
# For win-back email drafts (Resend or SendGrid)
# Use test API key for development
EMAIL_PROVIDER_API_KEY="your-email-provider-test-api-key"

# Environment
# Options: development, staging, production, test
NODE_ENV="development"

# Logging Configuration
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL="debug"

# AI Provider Configuration
# Choose your preferred LLM provider: anthropic, openai, or ollama
AI_PROVIDER="anthropic"

# Model tier: fast (cheaper/faster), balanced (default), or powerful (best quality)
AI_MODEL_TIER="balanced"

# Generation parameters
AI_MAX_TOKENS="2000"
AI_TEMPERATURE="0.7"

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# OpenAI (GPT-4) - https://platform.openai.com/
OPENAI_API_KEY=""

# Ollama (Local LLM) - No API key required
# Install: https://ollama.ai/
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# Fallback provider (optional) - used if primary fails
# AI_FALLBACK_PROVIDER=""

# Disable fallback templates (will throw errors instead of using deterministic templates)
# AI_ENABLE_FALLBACK_TEMPLATES="true"

# Webhook Configuration
# HMAC secret for verifying Shopify webhook authenticity
SHOPIFY_WEBHOOK_SECRET="your-webhook-secret-for-shopify-hmac-verification"

# Encryption Configuration
# Generate with: openssl rand -hex 32
# Used for encrypting Shopify access tokens at rest
ENCRYPTION_KEY="your-encryption-key-here-64-hex-chars"

# Optional: Rate Limiting
# RATE_LIMIT_MAX_REQUESTS="100"
# RATE_LIMIT_WINDOW_MS="60000"

# Optional: Session Configuration
# SESSION_MAX_AGE="2592000" # 30 days in seconds

# Optional: Feature Flags
# FEATURE_EMAIL_SENDING="false"
# FEATURE_AUTO_EXECUTION="false"
# FEATURE_LEARNING_LOOP="true"
