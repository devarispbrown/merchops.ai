# Database Configuration
# PostgreSQL connection string for Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://merchops:password@localhost:5432/merchops_dev?schema=public"

# Redis Configuration
# Redis connection string for BullMQ job queue and caching
# Format: redis://[username]:[password]@HOST:PORT/DATABASE
REDIS_URL="redis://localhost:6379/0"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"

# Application URL (update for production)
NEXTAUTH_URL="http://localhost:3000"

# Shopify OAuth Configuration
# Create a custom app in your Shopify Partner Dashboard
# https://partners.shopify.com/
SHOPIFY_CLIENT_ID="your-shopify-client-id"
SHOPIFY_CLIENT_SECRET="your-shopify-client-secret"

# Shopify OAuth Scopes
# Minimal required scopes for MVP functionality
SHOPIFY_SCOPES="read_products,write_products,read_orders,read_customers,read_inventory,write_inventory,write_discounts,read_price_rules,write_price_rules"

# Sentry Configuration (Error Tracking)
# Create project at https://sentry.io
# Leave empty to disable Sentry
SENTRY_DSN=""

# Email Provider Configuration
# For win-back email drafts (Resend or SendGrid)
# Use test API key for development
EMAIL_PROVIDER_API_KEY="your-email-provider-test-api-key"

# Environment
# Options: development, staging, production, test
NODE_ENV="development"

# Logging Configuration
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL="debug"

# AI Provider Configuration (Anthropic)
# Get your API key from https://console.anthropic.com/
# Leave empty to use fallback templates only
ANTHROPIC_API_KEY=""

# Webhook Configuration
# HMAC secret for verifying Shopify webhook authenticity
SHOPIFY_WEBHOOK_SECRET="your-webhook-secret-for-shopify-hmac-verification"

# Encryption Configuration
# Generate with: openssl rand -hex 32
# Used for encrypting Shopify access tokens at rest
ENCRYPTION_KEY="your-encryption-key-here-64-hex-chars"

# Optional: Rate Limiting
# RATE_LIMIT_MAX_REQUESTS="100"
# RATE_LIMIT_WINDOW_MS="60000"

# Optional: Session Configuration
# SESSION_MAX_AGE="2592000" # 30 days in seconds

# Optional: Feature Flags
# FEATURE_EMAIL_SENDING="false"
# FEATURE_AUTO_EXECUTION="false"
# FEATURE_LEARNING_LOOP="true"
