# =============================================================================
# MerchOps Environment Configuration
# =============================================================================
# Copy this file to .env and update the values.
#
# LOCAL DEVELOPMENT: Use non-standard ports to avoid conflicts:
#   - Next.js: 3847 (instead of 3000)
#   - PostgreSQL: 5847 (instead of 5432)
#   - Redis: 6847 (instead of 6379)
#
# PRODUCTION: Set all required variables in your hosting platform.
# =============================================================================

# =============================================================================
# REQUIRED - Core Configuration
# =============================================================================

# Database (PostgreSQL)
# Local: postgresql://merchops:merchops_dev_password@localhost:5847/merchops_dev
# Production: Your managed PostgreSQL connection string
DATABASE_URL="postgresql://merchops:merchops_dev_password@localhost:5847/merchops_dev?schema=public"

# Redis (for job queues)
# Local: redis://localhost:6847/0
# Production: Your managed Redis connection string
REDIS_URL="redis://localhost:6847/0"

# NextAuth Secret - REQUIRED
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# Application URL
# Local: http://localhost:3847
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3847"

# Trust host header (required for production behind reverse proxy)
# Set to "true" for Render, Vercel, or any reverse proxy
AUTH_TRUST_HOST="false"

# Encryption Key for Shopify tokens - REQUIRED
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="generate-64-hex-chars-with-openssl-rand-hex-32"

# =============================================================================
# REQUIRED - Shopify Store Integration
# =============================================================================
# Create a custom app in Shopify Partner Dashboard: https://partners.shopify.com/

# Shopify API credentials (for store data access)
SHOPIFY_CLIENT_ID="your-shopify-app-client-id"
SHOPIFY_CLIENT_SECRET="your-shopify-app-client-secret"

# OAuth scopes for store access
SHOPIFY_SCOPES="read_products,write_products,read_orders,read_customers,read_inventory,write_inventory,write_discounts,read_price_rules,write_price_rules"

# Webhook HMAC verification secret
# Generate with: openssl rand -hex 32
SHOPIFY_WEBHOOK_SECRET="your-webhook-hmac-secret"

# =============================================================================
# REQUIRED - AI Provider (choose one)
# =============================================================================

# Provider selection: anthropic | openai | ollama
AI_PROVIDER="anthropic"

# Model tier: fast | balanced | powerful
AI_MODEL_TIER="balanced"

# Generation parameters
AI_MAX_TOKENS="2000"
AI_TEMPERATURE="0.7"

# Anthropic (Claude) - https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI (GPT-4) - https://platform.openai.com/
# OPENAI_API_KEY="sk-..."

# Ollama (Local) - https://ollama.ai/ (no API key needed)
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3.2"

# =============================================================================
# OPTIONAL - Authentication Providers
# =============================================================================

# Google OAuth (for "Sign in with Google")
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Shopify OAuth for user authentication (separate from store integration)
# Can reuse SHOPIFY_CLIENT_ID/SECRET or create separate credentials
# Authorized redirect URI: https://your-domain.com/api/auth/callback/shopify
SHOPIFY_AUTH_CLIENT_ID=""
SHOPIFY_AUTH_CLIENT_SECRET=""

# =============================================================================
# OPTIONAL - Email (Magic Link & Notifications)
# =============================================================================

# Resend (recommended) - https://resend.com/
RESEND_API_KEY=""

# Email sender address
EMAIL_FROM_ADDRESS="MerchOps <noreply@your-domain.com>"

# Alternative: SendGrid
# SENDGRID_API_KEY=""

# Sandbox mode (emails logged but not sent)
# EMAIL_SANDBOX_MODE="true"

# =============================================================================
# OPTIONAL - Monitoring & Logging
# =============================================================================

# Environment identifier
NODE_ENV="development"

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="debug"

# Sentry error tracking - https://sentry.io/
SENTRY_DSN=""
# SENTRY_ENVIRONMENT="development"
# DISABLE_SENTRY="true"

# =============================================================================
# OPTIONAL - Stripe Payments
# =============================================================================
# Create account at: https://dashboard.stripe.com/
# Set up products/prices for Starter ($49), Growth ($149), Pro ($399)

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs from Stripe Dashboard (Products > Prices)
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_GROWTH_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."

# =============================================================================
# OPTIONAL - Advanced Configuration
# =============================================================================

# Redis (alternative to REDIS_URL)
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""
# REDIS_TLS="false"

# Worker configuration
# WORKER_CONCURRENCY="5"

# AI fallback
# AI_FALLBACK_PROVIDER="openai"
# AI_ENABLE_FALLBACK_TEMPLATES="true"

# =============================================================================
# LOCAL DEVELOPMENT QUICK START
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Start databases: docker compose up -d
# 3. Generate secrets:
#    - NEXTAUTH_SECRET: openssl rand -base64 32
#    - ENCRYPTION_KEY: openssl rand -hex 32
# 4. Get Shopify credentials from Partner Dashboard
# 5. Get Anthropic API key from console.anthropic.com
# 6. Run migrations: pnpm prisma:migrate
# 7. Start dev server: pnpm dev
#
# =============================================================================
# PRODUCTION CHECKLIST (Render)
# =============================================================================
# Required environment variables to set in Render dashboard:
#
# [Auto-configured by Render Blueprint]
# - DATABASE_URL (from merchops-db)
# - REDIS_URL (from merchops-redis)
# - NEXTAUTH_SECRET (auto-generated)
# - ENCRYPTION_KEY (auto-generated)
# - SHOPIFY_WEBHOOK_SECRET (auto-generated)
# - AUTH_TRUST_HOST=true
#
# [Must set manually - Secrets]
# - NEXTAUTH_URL=https://your-domain.com
# - SHOPIFY_CLIENT_ID
# - SHOPIFY_CLIENT_SECRET
# - ANTHROPIC_API_KEY (or OPENAI_API_KEY)
#
# [Optional - Enhanced features]
# - GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET (Google OAuth)
# - RESEND_API_KEY (Magic link + emails)
# - SENTRY_DSN (Error tracking)
# - STRIPE_SECRET_KEY + STRIPE_PUBLISHABLE_KEY + STRIPE_WEBHOOK_SECRET (Billing)
# - STRIPE_*_PRICE_ID (Product price IDs)
# =============================================================================
